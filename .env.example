# CodeOrbit AI Environment Configuration
# Copy this file to .env and configure the variables accordingly

# Gemini API Key (Required for model execution)
GEMINI_API_KEY=your_gemini_api_key_here

# LLM Model Configuration
DEFAULT_MODEL=gemini-2.5-flash
PLANNER_MODEL=gemini-2.5-flash
RESEARCHER_MODEL=gemini-2.5-flash
DEVELOPER_MODEL=gemini-2.5-flash
REVIEWER_MODEL=gemini-2.5-flash

# API Server Host and Port Configuration
API_HOST=127.0.0.1
API_PORT=8000

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Persistence Directory for SQLite DB and Logs
PERSIST_DIR=data
